# Copy to .env.local for local dev (vercel dev), and paste the same values
# into Vercel Project → Settings → Environment Variables for production.

# Resend — for the email path of "Send invoice"
RESEND_API_KEY=re_your_key_here

# Cloudflare Turnstile — verifies the captcha token issued in the browser.
# Dev test key (always passes):  1x0000000000000000000000000000000AA
# Real production key:           Cloudflare dash → Turnstile → Site → Secret Key
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Display "From" address for outbound invoice emails. Domain must be verified
# in Resend (Settings → Domains → Add → invoicepass.app or make.invoicepass.app).
EMAIL_FROM=InvoicePass <invoices@make.invoicepass.app>
